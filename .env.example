# SearchBox — example environment file.
# Copy to .env and edit. Values below are safe dev defaults; regenerate
# keys before exposing this to anything beyond localhost.

# Session cookie signing. Generate with:
#   openssl rand -hex 32
SEARCHBOX_SECRET_KEY=change-me-to-a-random-secret

# Meilisearch master key. Generate with:
#   openssl rand -hex 32
MEILI_MASTER_KEY=change-me-to-a-random-key

# Bind address + port for the app.
SEARCHBOX_HOST=0.0.0.0
SEARCHBOX_PORT=8080

# Meilisearch sidecar port (entrypoint.sh uses this).
MEILI_PORT=7700

# Ollama URL if you want AI summaries. Leave unset to disable.
# In Docker, host.docker.internal points at the host machine.
# OLLAMA_URL=http://host.docker.internal:11434
